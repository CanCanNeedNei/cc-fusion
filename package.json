{
  "name": "cc-fusion",
  "version": "2.0.1",
  "description": "Claude Code statusline: CCometixLine beauty + Claude HUD functionality",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cc-fusion": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "docs/assets/",
    "README.md",
    "README.zh.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod 755 dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "plugin",
    "cc-fusion",
    "nerd-font"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CanCanNeedNei/cc-fusion.git"
  },
  "homepage": "https://github.com/CanCanNeedNei/cc-fusion",
  "bugs": {
    "url": "https://github.com/CanCanNeedNei/cc-fusion/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {}
}
